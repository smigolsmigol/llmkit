{
  "name": "@f3d1/llmkit-shared",
  "version": "0.0.6",
  "license": "MIT",
  "description": "Shared types, pricing data, and constants for LLMKit packages",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smigolsmigol/llmkit.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "llm",
    "ai",
    "openai",
    "anthropic",
    "pricing",
    "cost-tracking",
    "token-usage"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/smigolsmigol/llmkit/tree/main/packages/shared",
  "bugs": {
    "url": "https://github.com/smigolsmigol/llmkit/issues"
  },
  "author": {
    "name": "f3d1",
    "url": "https://github.com/smigolsmigol"
  }
}
