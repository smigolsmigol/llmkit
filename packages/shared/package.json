{
  "name": "@f3d1/llmkit-shared",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Shared types, pricing data, and constants for LLMKit packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": ["llm", "ai", "openai", "anthropic", "pricing", "cost-tracking", "token-usage"],
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}
