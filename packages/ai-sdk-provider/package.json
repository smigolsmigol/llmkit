{
  "name": "@f3d1/llmkit-ai-sdk-provider",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Vercel AI SDK v6 custom provider for LLMKit proxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smigolsmigol/llmkit.git",
    "directory": "packages/ai-sdk-provider"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "vercel-ai-sdk",
    "ai-sdk",
    "llm",
    "openai",
    "anthropic",
    "provider",
    "ai-gateway",
    "cost-tracking"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.10"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "homepage": "https://github.com/smigolsmigol/llmkit/tree/main/packages/ai-sdk-provider",
  "bugs": {
    "url": "https://github.com/smigolsmigol/llmkit/issues"
  },
  "author": {
    "name": "f3d1",
    "url": "https://github.com/smigolsmigol"
  }
}
