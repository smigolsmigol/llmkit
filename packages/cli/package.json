{
  "name": "@f3d1/llmkit-cli",
  "version": "0.0.9",
  "license": "MIT",
  "type": "module",
  "description": "Zero-code AI cost tracking. Wraps any command, intercepts API calls, prints cost summary.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smigolsmigol/llmkit.git",
    "directory": "packages/cli"
  },
  "bin": {
    "llmkit": "dist/index.js"
  },
  "main": "./dist/index.js",
  "keywords": [
    "llm",
    "ai",
    "cli",
    "openai",
    "anthropic",
    "cost-tracking",
    "python",
    "proxy",
    "ai-agents",
    "budget"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@f3d1/llmkit-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "homepage": "https://github.com/smigolsmigol/llmkit/tree/main/packages/cli",
