{
  "manifest_version": "0.2",
  "name": "@f3d1/llmkit-mcp-server",
  "version": "0.4.3",
  "description": "AI cost tracking: 14 tools for spend, budgets, local costs (Claude Code + Cline + Cursor), and Notion sync",
  "author": {
    "name": "F3d1",
    "url": "https://github.com/smigolsmigol"
  },
  "server": {
    "type": "node",
    "entry_point": "./dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/./dist/index.js"
      ],
      "env": {
        "LLMKIT_API_KEY": "",
        "NOTION_TOKEN": "",
        "NOTION_PAGE_ID": ""
      }
    }
  },
  "license": "MIT"
}
