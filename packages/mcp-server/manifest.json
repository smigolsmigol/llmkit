{
  "manifest_version": "0.2",
  "name": "@f3d1/llmkit-mcp-server",
  "version": "0.4.6",
  "description": "AI cost tracking: 11 tools for spend, budgets, and local costs (Claude Code + Cline + Cursor)",
  "author": {
    "name": "F3d1",
    "url": "https://github.com/smigolsmigol"
  },
  "server": {
    "type": "node",
    "entry_point": "./dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/./dist/index.js"
      ],
      "env": {
        "LLMKIT_API_KEY": ""
      }
    }
  },
  "license": "MIT"
}
