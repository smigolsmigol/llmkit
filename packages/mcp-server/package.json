{
  "name": "@f3d1/llmkit-mcp-server",
  "version": "0.4.1",
  "license": "MIT",
  "description": "AI cost tracking: 14 tools for spend, budgets, Claude Code costs, and Notion sync",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smigolsmigol/llmkit.git"
  },
  "type": "module",
  "bin": {
