{
  "name": "@f3d1/llmkit-mcp-server",
  "version": "0.0.2",
  "license": "MIT",
  "description": "MCP server for LLMKit - cost queries, session summaries, budget monitoring via Claude Code and Cursor",
  "type": "module",
  "bin": {
    "llmkit-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@f3d1/llmkit-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
