{
  "name": "@f3d1/llmkit-sdk",
  "version": "0.0.7",
  "license": "MIT",
  "description": "Client SDK for LLMKit - cost tracking, provider routing, budget enforcement",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smigolsmigol/llmkit.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "llm",
    "ai",
    "openai",
    "anthropic",
    "sdk",
    "api-gateway",
    "cost-tracking",
    "budget",
    "ai-agents",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@f3d1/llmkit-shared": "workspace:*"
  },
  "homepage": "https://github.com/smigolsmigol/llmkit/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/smigolsmigol/llmkit/issues"
  },
  "author": {
    "name": "f3d1",
    "url": "https://github.com/smigolsmigol"
  }
}
