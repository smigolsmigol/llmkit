{
  "name": "@llmkit/sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for LLMKit - cost tracking, provider routing, budget enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@llmkit/shared": "workspace:*"
  }
}
