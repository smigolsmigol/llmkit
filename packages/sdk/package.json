{
  "name": "@f3d1/llmkit-sdk",
  "version": "0.0.3",
  "license": "MIT",
  "description": "Client SDK for LLMKit - cost tracking, provider routing, budget enforcement",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smigolsmigol/llmkit.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": ["llm", "ai", "openai", "anthropic", "sdk", "api-gateway", "cost-tracking", "budget", "ai-agents", "typescript"],
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@f3d1/llmkit-shared": "workspace:*"
  }
}
