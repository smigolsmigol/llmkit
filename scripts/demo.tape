Output .github/demo.gif

Set Shell "bash"
Set FontFamily "Cascadia Code"
Set FontSize 14
Set Width 900
Set Height 520
Set Padding 16
Set Theme { "background": "#0a0a0f", "foreground": "#c8c8d0", "cursor": "#c8c8d0", "selection": "#333355", "black": "#0a0a0f", "red": "#ff5555", "green": "#4ade80", "yellow": "#fbbf24", "blue": "#6c6cff", "magenta": "#c084fc", "cyan": "#22d3ee", "white": "#e8e8f0", "brightBlack": "#5a5a6e", "brightRed": "#ff7777", "brightGreen": "#6ee7a0", "brightYellow": "#fcd34d", "brightBlue": "#8888ff", "brightMagenta": "#d4a0ff", "brightCyan": "#67e8f9", "brightWhite": "#f8f8ff" }

Hide
Type "export PS1=''"
Enter
Sleep 50ms
Type "node scripts/demo.js"
Enter
Sleep 300ms
Show
Sleep 14s
